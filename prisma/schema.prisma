generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyCode {
  Q_HOME
  WARCO
  TOMME
}

enum UserRole {
  ADMIN
  REQUESTER
  TECHNICAL_QUOTATION_MAKER
  REVIEWER
}

enum TechniqueCode {
  ELECTRICITY
  HVAC
  SOLAR_PANELS
  BATTERY
  CHARGING_STATIONS
  DOMOTICS_LOXONE
  ENERGY_MANAGEMENT_Q_ENERGY_AI
  SANITARY
}

enum QuotationRequestStatus {
  DRAFT
  SUBMITTED
  IN_PROGRESS
  READY_FOR_REVIEW
  APPROVED
  REJECTED
}

enum SectionSource {
  TEMPLATE
  TASK
  EXTERNAL_UPLOAD
}

enum SectionStatus {
  GENERATED
  WAITING_FOR_TASK
  UPLOADED
  REVIEWED
  APPROVED
  REJECTED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_INFO
  UPLOADED
  REVIEWED
  APPROVED
  REJECTED
}

enum DocumentType {
  CUSTOMER_QUOTATION
  TECHNICAL_OFFER
  PLAN
  SPECIFICATION
  OTHER
}

enum FinalQuotationStatus {
  DRAFT
  READY
  SENT
  ACCEPTED
  REJECTED
}

model Company {
  id                   String             @id @default(cuid())
  code                 CompanyCode        @unique
  name                 String
  legalName            String?
  color                String
  users                User[]
  requestingRequests   QuotationRequest[] @relation("RequestingCompany")
  requestedTasks       Task[]             @relation("RequestedCompany")
  templates            Template[]
  defaultForTechniques Technique[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  role              UserRole
  companyId         String
  company           Company            @relation(fields: [companyId], references: [id])
  requestedQuotes   QuotationRequest[] @relation("Requester")
  uploadedDocuments UploadedDocument[] @relation("UploadedBy")
  assignedTasks     Task[]             @relation("Assignee")
  requestedTasks    Task[]             @relation("TaskRequester")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Customer {
  id                String             @id @default(cuid())
  companyName       String
  vatNumber         String?
  contactName       String
  contactEmail      String?
  phone             String?
  street            String
  postalCode        String
  city              String
  country           String             @default("BE")
  quotationRequests QuotationRequest[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Technique {
  id                    String             @id @default(cuid())
  code                  TechniqueCode      @unique
  label                 String
  description           String
  defaultOwnerCompanyId String?
  defaultOwnerCompany   Company?           @relation(fields: [defaultOwnerCompanyId], references: [id])
  templates             Template[]
  sections              QuotationSection[]
  tasks                 Task[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}

model QuotationRequest {
  id                  String                 @id @default(cuid())
  requestNumber       String                 @unique
  status              QuotationRequestStatus @default(SUBMITTED)
  projectName         String
  projectDescription  String
  requestedDueDate    DateTime?
  requesterCompanyId  String
  requesterCompany    Company                @relation("RequestingCompany", fields: [requesterCompanyId], references: [id])
  requesterId         String
  requester           User                   @relation("Requester", fields: [requesterId], references: [id])
  customerId          String
  customer            Customer               @relation(fields: [customerId], references: [id])
  uploadedDocuments   UploadedDocument[]
  sections            QuotationSection[]
  tasks               Task[]
  finalQuotation      FinalQuotation?
  submittedAt         DateTime               @default(now())
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
}

model UploadedDocument {
  id                 String            @id @default(cuid())
  quotationRequestId String?
  quotationRequest   QuotationRequest? @relation(fields: [quotationRequestId], references: [id], onDelete: Cascade)
  taskId             String?
  task               Task?             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById       String?
  uploadedBy         User?             @relation("UploadedBy", fields: [uploadedById], references: [id])
  type               DocumentType
  fileName           String
  mimeType           String
  size               Int
  storagePath        String
  createdAt          DateTime          @default(now())
}

model QuotationSection {
  id                 String          @id @default(cuid())
  quotationRequestId String
  quotationRequest   QuotationRequest @relation(fields: [quotationRequestId], references: [id], onDelete: Cascade)
  techniqueId        String
  technique          Technique       @relation(fields: [techniqueId], references: [id])
  source             SectionSource
  status             SectionStatus   @default(GENERATED)
  title              String
  content            String?
  templateId         String?
  template           Template?       @relation(fields: [templateId], references: [id])
  externalDocumentId String?
  sortOrder          Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model Task {
  id                 String           @id @default(cuid())
  quotationRequestId String
  quotationRequest   QuotationRequest @relation(fields: [quotationRequestId], references: [id], onDelete: Cascade)
  techniqueId        String
  technique          Technique        @relation(fields: [techniqueId], references: [id])
  requesterId        String
  requester          User             @relation("TaskRequester", fields: [requesterId], references: [id])
  requestedCompanyId String?
  requestedCompany   Company?         @relation("RequestedCompany", fields: [requestedCompanyId], references: [id])
  assigneeId         String?
  assignee           User?            @relation("Assignee", fields: [assigneeId], references: [id])
  status             TaskStatus       @default(OPEN)
  title              String
  instructions       String
  dueDate            DateTime?
  uploads            UploadedDocument[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Template {
  id          String             @id @default(cuid())
  title       String
  companyId   String?
  company     Company?           @relation(fields: [companyId], references: [id])
  techniqueId String
  technique   Technique          @relation(fields: [techniqueId], references: [id])
  content     String
  active      Boolean            @default(true)
  version     Int                @default(1)
  sections    QuotationSection[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([companyId, techniqueId, version])
}

model FinalQuotation {
  id                 String               @id @default(cuid())
  quotationRequestId String               @unique
  quotationRequest   QuotationRequest     @relation(fields: [quotationRequestId], references: [id], onDelete: Cascade)
  version            Int                  @default(1)
  status             FinalQuotationStatus @default(DRAFT)
  pdfPath            String?
  totalNet           Decimal?             @db.Decimal(12, 2)
  totalVat           Decimal?             @db.Decimal(12, 2)
  totalGross         Decimal?             @db.Decimal(12, 2)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model PlenionSnapshot {
  id                   String                 @id @default(cuid())
  sourceRoot           String
  generatedAt          DateTime
  invoiceXmlCount      Int
  workOrderXmlCount    Int
  supplierOrderXmlCount Int
  notes                String?
  invoices             PlenionInvoice[]
  workOrders           PlenionWorkOrder[]
  supplierOrders       PlenionSupplierOrder[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([generatedAt])
}

model PlenionInvoice {
  id            String          @id @default(cuid())
  snapshotId    String
  snapshot      PlenionSnapshot  @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  sourceFileName String
  invoiceNumber String
  issueDate     DateTime
  dueDate       DateTime?
  note          String?
  supplierName  String?
  customerName  String?
  netAmount     Decimal         @db.Decimal(12, 2)
  vatAmount     Decimal         @db.Decimal(12, 2)
  grossAmount   Decimal         @db.Decimal(12, 2)
  lineCount     Int             @default(0)
  raw           Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([snapshotId, sourceFileName])
  @@index([snapshotId, issueDate])
  @@index([invoiceNumber])
}

model PlenionWorkOrder {
  id             String          @id @default(cuid())
  snapshotId    String
  snapshot      PlenionSnapshot  @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  sourceFileName String
  bonNumber     String
  customerCode  String?
  workDate      DateTime
  workTime      String?
  reference     String?
  workReady     Boolean         @default(false)
  firstArticleCode String?
  quantity      Decimal?        @db.Decimal(12, 3)
  resourceCode  String?
  startTime     String?
  endTime       String?
  durationHours Decimal?        @db.Decimal(12, 2)
  lineCount     Int             @default(0)
  gpsStartLat   Decimal?        @db.Decimal(12, 8)
  gpsStopLat    Decimal?        @db.Decimal(12, 8)
  raw           Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([snapshotId, sourceFileName])
  @@index([snapshotId, workDate])
  @@index([bonNumber])
}

model PlenionSupplierOrder {
  id                String          @id @default(cuid())
  snapshotId       String
  snapshot         PlenionSnapshot  @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  sourceFileName    String
  customerOrderId   String
  customerOrderRef  String?
  orderDate         DateTime
  deliverTo         String?
  city              String?
  lineCount         Int             @default(0)
  supplierItemIds   String[]
  raw               Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([snapshotId, sourceFileName])
  @@index([snapshotId, orderDate])
  @@index([customerOrderId])
}

model PlenionSupplierCatalogSnapshot {
  id              String                      @id @default(cuid())
  sourceRoot      String
  generatedAt     DateTime
  workbookCount   Int
  supplierCount   Int
  itemCount       Int
  notes           String?
  items           PlenionSupplierCatalogItem[]
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  @@index([generatedAt])
}

model PlenionSupplierCatalogItem {
  id             String                         @id @default(cuid())
  snapshotId     String
  snapshot       PlenionSupplierCatalogSnapshot  @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  supplierName   String
  sourceFileName String
  sourceSheetName String
  sourceRow      Int
  itemCode       String
  itemNameNl     String?
  itemNameFr     String?
  series         String?
  type           String?
  branch         String?
  listPrice      Decimal                        @db.Decimal(12, 2)
  netPrice       Decimal                        @db.Decimal(12, 2)
  discountRate   Decimal?                       @db.Decimal(8, 4)
  modelRange     String?
  currency       String                         @default("EUR")
  priceSource    String
  raw            Json?
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt

  @@unique([snapshotId, supplierName, itemCode])
  @@index([snapshotId, supplierName])
  @@index([itemCode])
}
